---
import DocsLayout from '../layouts/DocsLayout.astro';
---

<DocsLayout frontmatter={{ title: "申请使用 - 葱喵工厂", description: "申请将葱喵Bot加入你的群聊" }}>
  <div class="apply-container">
    <div class="apply-header">
      <h1>申请使用葱喵Bot</h1>
      <p>欢迎申请！请填写以下基本信息，我们会尽快进行审核并通知你~</p>
    </div>

    <!-- 
      推荐通知方案 A：使用 Formspree (发邮件通知)
      使用方法：去 https://formspree.io/ 免费注册，创建一个 form，把 action 里的 YOUR_FORM_ID 换掉即可。
    -->

    <form id="applyForm" class="apply-form">
      
      <div class="form-group">
        <label for="contact">你的联系方式 (QQ号) <span class="required">*</span></label>
        <input type="text" id="contact" name="contact" placeholder="例如: 12345678" required />
      </div>

      <div class="form-group">
        <label for="group">群聊号码 <span class="required">*</span></label>
        <input type="text" id="group" name="group" placeholder="例如: 87654321" required />
      </div>

      <div class="form-group">
        <label for="bot_choice">选择申请入群的 Bot 实例 <span class="required">*</span></label>
        <select id="bot_choice" name="bot_choice" required>
          <option value="" disabled selected>请选择需要邀请的Bot</option>
          <option value="bot1">一号机 (仅包含 Haruki Neo 功能)</option>
          <option value="bot2">二号机 (包含 Haruki Neo、Maimai查询 及其他综合功能)</option>
        </select>
      </div>

      <div class="form-group">
        <label for="message">补充说明 / 备注</label>
        <textarea id="message" name="message" rows="4" placeholder="有什么想对主人们说的话，或者补充说明你的群聊大概是什么性质的群..." ></textarea>
      </div>

      <div class="form-group checkbox-group">
        <label class="custom-checkbox">
          <input type="checkbox" name="agree_terms" required>
          <span class="checkmark"></span>
          <span class="checkbox-text">我已阅读并同意<a href="/terms/" target="_blank">《用户协议与隐私条款》</a> <span class="required">*</span></span>
        </label>
      </div>

      <div class="captcha-container">
        <div class="h-captcha" data-sitekey="d1243d18-c1c0-414a-8da8-2d1a2b501f76"></div>
      </div>

      <div class="form-actions">
        <div id="result" class="result-message" style="display: none;"></div>
        <button type="submit" class="submit-btn" id="submitBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
          <span id="submitText">提交申请</span>
        </button>
      </div>

    </form>
  </div>
</DocsLayout>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById('applyForm') as HTMLFormElement;
    const result = document.getElementById('result');
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');

    if (form && result && submitBtn && submitText) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // 改变按钮状态
        submitText.innerHTML = "正在提交...";
        submitBtn.disabled = true;
        submitBtn.style.opacity = "0.7";

        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        result.style.display = "block";
        result.innerHTML = "⏳ 正在发送请求...";
        result.className = "result-message info";

        fetch('https://tgbot2.hyw.mom/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: json
        })
        .then(async (response) => {
          let jsonResponse = await response.json();
          if (response.status == 200) {
            result.innerHTML = "✅ 我们会尽快通过您的申请！";
            result.className = "result-message success";
            form.reset();
          } else {
            console.log(response);
            result.innerHTML = "❌ 提交失败：" + jsonResponse.message;
            result.className = "result-message error";
          }
        })
        .catch(error => {
          console.log(error);
          result.innerHTML = "❌ 网络连接异常，请检查网络后重试。";
          result.className = "result-message error";
        })
        .finally(() => {
          submitText.innerHTML = "重新提交";
          submitBtn.disabled = false;
          submitBtn.style.opacity = "1";
        });
      });
    }
  });
</script>

<style>
  .apply-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 20px 0;
  }
  .apply-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .apply-header h1 {
    font-size: 2.2rem;
    background: linear-gradient(135deg, #2e7d32 0%, #81c784 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 12px;
  }
  .apply-header p {
    color: #546e7a;
    font-size: 1rem;
  }
  .apply-form {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 40px;
    border-radius: 24px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0,0,0,0.02);
    border: 1px solid rgba(255, 255, 255, 0.6);
  }
  .form-group {
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
  }
  .form-group label {
    font-size: 0.95rem;
    font-weight: bold;
    color: #37474f;
    margin-bottom: 8px;
  }
  .checkbox-group {
    flex-direction: row;
    margin-bottom: 20px;
  }
  .custom-checkbox {
    display: flex;
    align-items: center;
    position: relative;
    cursor: pointer;
    font-weight: normal !important;
    user-select: none;
    padding-left: 32px;
  }
  .custom-checkbox input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }
  .checkmark {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    height: 22px;
    width: 22px;
    background-color: #f4f7f4;
    border: 2px solid #cfd8dc;
    border-radius: 6px;
    transition: all 0.2s ease;
  }
  .custom-checkbox:hover input ~ .checkmark {
    background-color: #eef2ee;
    border-color: #b0bec5;
  }
  .custom-checkbox input:checked ~ .checkmark {
    background-color: #4caf50;
    border-color: #4caf50;
  }
  .checkmark:after {
    content: "";
    position: absolute;
    display: none;
  }
  .custom-checkbox input:checked ~ .checkmark:after {
    display: block;
  }
  .custom-checkbox .checkmark:after {
    left: 7px;
    top: 3px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .checkbox-text {
    font-size: 0.95rem;
    color: #546e7a;
  }
  .checkbox-text a {
    color: #4caf50;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: bold;
    transition: color 0.2s ease;
  }
  .checkbox-text a:hover {
    color: #388e3c;
  }
  .required {
    color: #e53935;
    margin-left: 4px;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 14px 18px;
    font-size: 1rem;
    border: 2px solid transparent;
    border-radius: 14px;
    background: #f4f7f4;
    color: #263238;
    font-family: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    outline: none;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);
  }
  .form-group textarea {
    resize: none;
  }
  .form-group input:hover,
  .form-group select:hover,
  .form-group textarea:hover {
    background: #eef2ee;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    background: #fff;
    border-color: #81c784;
    box-shadow: 0 0 0 4px rgba(129, 199, 132, 0.15), inset 0 1px 2px rgba(0,0,0,0.01);
  }
  .captcha-container {
    display: flex;
    justify-content: center;
    margin: 20px 0 30px;
  }
  .form-actions {
    margin-top: 32px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    flex-wrap: wrap;
  }
  .result-message {
    font-size: 0.95rem;
    font-weight: bold;
    padding: 10px 16px;
    border-radius: 10px;
    flex: 1;
    min-width: 200px;
  }
  .result-message.info {
    color: #0277bd;
    background: #e1f5fe;
  }
  .result-message.success {
    color: #2e7d32;
    background: #e8f5e9;
  }
  .result-message.error {
    color: #c62828;
    background: #ffebee;
  }
  .submit-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #4caf50;
    color: white;
    border: none;
    padding: 12px 32px;
    font-size: 1.05rem;
    font-weight: bold;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
  }
  .submit-btn svg {
    width: 20px;
    height: 20px;
  }
  .submit-btn:hover {
    background: #43a047;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(76, 175, 80, 0.4);
  }
  .submit-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(76, 175, 80, 0.3);
  }

  /* 移动端响应式适配 */
  @media (max-width: 600px) {
    .apply-form {
      padding: 24px 16px; /* 减少手机端左右留白，为验证码腾出空间 */
    }
    .apply-header h1 {
      font-size: 1.8rem;
    }
    .form-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .submit-btn {
      justify-content: center;
      width: 100%;
    }
  }

  /* 针对极窄屏幕（如 iPhone SE 等）进行强制缩放 */
  @media (max-width: 380px) {
    .captcha-container {
      transform: scale(0.85); /* hCaptcha原生宽度304px，按比例缩小防出框 */
      transform-origin: center;
      margin: 10px -20px; /* 补偿缩小后的外边距 */
    }
  }
</style>
